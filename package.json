    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.400.0",
    "mysql2": "^3.20.0",
    "next": "^15.5.19",
    "pino": "^9.14.0",
    "react": "^18",
    "react-dom": "^18",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "overrides": {
    "nanoid": "^3.3.8",
    "lodash-es": "^4.18.1",
    "rimraf": {
