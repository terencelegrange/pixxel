{
  "name": "halo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https --experimental-https-key ./certificates/localhost+2-key.pem --experimental-https-cert ./certificates/localhost+2.pem",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --selectProjects unit ui --passWithNoTests",
    "test:coverage": "jest --selectProjects unit ui --passWithNoTests --coverage",
    "test:integration": "jest --selectProjects integration --passWithNoTests",
    "test:all": "jest --passWithNoTests",
    "seed:demo": "ts-node --project tsconfig.seed.json scripts/seed-demo.ts",
    "db:generate:sqlite": "drizzle-kit generate --config drizzle.config.sqlite.ts"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@excalidraw/excalidraw": "^0.18.0",
    "@tailwindcss/typography": "^0.5.19",
